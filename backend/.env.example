# Application
APP_NAME=StudyMind
DEBUG=false
SECRET_KEY=change-this-to-a-long-random-secret-key-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database
DATABASE_URL=sqlite:///./studymind.db

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# File uploads
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10

# Embeddings model (sentence-transformers)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Retrieval
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K_RESULTS=5

# Optional: OpenAI for enhanced answers (leave empty for retrieval-only)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
